: 0;\n        padding: 16px;\n        background: white;\n        text-align: center;\n        font-size: 14px;\n        box-shadow: 0px -2px 8px rgba(0, 0, 0, 0.08);\n        z-index: 1000;\n      }\n\n      .btn {\n        background: var(--brand-color);\n        color: #fff;\n        font-weight: 700;\n        font-size: 16px;\n        padding: 12px 24px;\n        text-decoration: none;\n        border-radius: 999px;\n        cursor: pointer;\n        border: none;\n        margin: 0 4px;\n        display: inline-block;\n        transition: all 0.2s;\n      }\n\n      .btn:hover {\n        transform: translateY(-2px);\n        box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.2);\n      }\n\n      .btn.inverse {\n        background: transparent;\n        border: 2px solid var(--brand-color);\n        color: var(--brand-color);\n      }\n\n      .btn.inverse:hover {\n        background: var(--brand-color);\n        color: white;\n      }\n    </style>\n  </head>\n\n  <body>\n    <div class=\"header\">\n      \n      <img\n        src=\"https://media.brand.dev/5e0b00a3-9c64-475c-a23d-c05851177445.jpg\"\n        alt=\"chakra_payment_labs Logo\"\n        style=\"max-width: 200px; max-height: 72px; object-fit: contain\"\n      />\n      \n    </div>\n\n    <div class=\"container\">\n      <div class=\"cards-grid\">\n        \n        <div class=\"card\">\n          <iframe\n            src=\"https://7dxperts.thoughtspot.cloud/?embedApp=true&orgId=737558137&hideActions=true#/embed/viz/c37c9cfd-ff82-4661-b3d1-044015e08c77/3bd0e24f-2128-4718-a5f0-c1981dbacd65\"\n            width=\"100%\"\n            height=\"280\"\n            style=\"border: none; border-radius: 12px; background: #fff\"\n          ></iframe>\n        </div>\n         \n        <div class=\"card\">\n          <iframe\n            src=\"https://7dxperts.thoughtspot.cloud/?embedApp=true&orgId=737558137&hideActions=true#/embed/viz/c37c9cfd-ff82-4661-b3d1-044015e08c77/ee8ba225-02c1-4d2d-bf4a-2f0858e3c4ab\"\n       