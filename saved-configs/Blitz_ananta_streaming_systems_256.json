      "icon": "home",
      "homePageType": "html",
      "homePageValue": "\n\n<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Benifex Analytics Dashboard</title>\n\n    <!-- ThoughtSpot Visual Embed SDK -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@thoughtspot/visual-embed-sdk/dist/tsembed.js\"></script>\n\n    <style>\n      @import url(\"https://fonts.googleapis.com/css2?family=Work+Sans:ital,wght@0,100..900;1,100..900&display=swap\");\n\n      :root {\n        --brand-green: #e40404;\n        --text-dark: #1c1c1c;\n        --text-muted: #6b7280;\n        --card-bg: #ffffff;\n        --card-border: #e5e7eb;\n        --filter-bg: #82f976;\n      }\n      body {\n        font-family: \"Work Sans\", sans-serif;\n        background: var(--brand-green);\n        margin: 0;\n        padding: 0;\n        color: var(--text-dark);\n        padding: 32px;\n      }\n      .flex {\n        display: flex;\n      }\n      .flex-row {\n        flex-direction: row;\n      }\n      .flex-initial {\n        flex: 0 1 auto;\n      }\n      .flex-1 {\n        flex: 1 1 0%;\n      }\n      .header {\n        background: white;\n        margin: 0 auto 16px;\n        padding: 26px 0;\n        border-radius: 16px;\n        text-align: center;\n      }\n      .container {\n        margin: 0 auto;\n        padding: 24px;\n        background: white;\n        border-radius: 16px;\n      }\n      .title {\n        font-size: 19px;\n        line-height: 28px;\n        margin: 0 auto 20px;\n        padding: 20px;\n        text-align: center;\n        color: #555;\n        max-width: 1000px;\n        font-family: \"Work Sans\", sans-serif;\n      }\n      .filter-title {\n        font-weight: 600;\n        font-size: 16px;\n        margin-right: 12px;\n        padding-top: 4px;\n      }\n      .filters .chip {\n        margin-right: 12px;\n        background: var(--filter-bg);\n        padding: 6px 12px;\n        border-radius: 20px;\n        font-weight: 600;\n        cursor: pointer;\n        transition: all 0.2s;\n      }\n      .filters .chip:hover {\n        background: #6fe561;\n        transform: translateY(-1px);\n      }\n      .filters .chip.active {\n        background: #17c100;\n        color: white;\n      }\n      .filters .chip-count {\n        background: black;\n        color: #fff;\n        font-size: 14px;\n        width: 31px;\n        height: 31px;\n        line-height: 31px;\n        text-align: center;\n        border-radius: 20px;\n      }\n      .cards-grid {\n        display: grid;\n        grid-template-columns: repeat(4, 1fr);\n        gap: 16px;\n        padding-bottom: 16px;\n        margin-top: 24px;\n      }\n      .card {\n        background: var(--card-bg);\n        border: 1px solid var(--card-border);\n        border-radius: 16px;\n        padding: 14px;\n        box-shadow: 0px 2px 12px rgba(0, 0, 0, 0.06);\n      }\n      .footer {\n        position: fixed;\n        bottom: 0;\n        left: 0;\n        right: 0;\n        padding: 16px;\n        background: white;\n        text-align: center;\n        font-size: 14px;\n      }\n      .btn {\n        background: var(--brand-green);\n        color: #fff;\n        font-weight: 700;\n        font-size: 16px;\n        padding: 12px 24px;\n        text-decoration: none;\n        border-radius: 999px;\n        cursor: pointer;\n        border: none;\n        margin: 0 4px;\n      }\n      .btn.inverse {\n        background: transparent;\n        border: 1px solid var(--brand-green);\n        color: var(--brand-green);\n      }\n    </style>\n  </head>\n\n  <body>\n    <div class=\"header\">\n      <img\n        src=\"https://benifex.com/wp-content/themes/hello-elementor-child/img/logo-benifex.jpg\"\n        alt=\"Benifex Logo\"\n        style=\"max-width: 200px; max-height: 72px\"\n      />\n    </div>\n    <div class=\"container\">\n      <div class=\"title\"></div>\n      <div class=\"flex flex-row\">\n        <div class=\"flex-initial filter-title\">Filters:</div>\n        <div class=\"flex flex-row flex-1 filters\">\n          <div class=\"chip\" data-col=\"Country\">Country (Select)</div>\n          <div class=\"chip\" data-col=\"Customer Segment\">\n            Customer Segment (Select)\n          </div>\n          <div class=\"chip\" data-col=\"Product Suite\">Product (Select)</div>\n          <div class=\"chip\" data-col=\"Calendar Date\">Date (Select)</div>\n        </div>\n      </div>\n      <div class=\"cards-grid\">\n        \n        <div class=\"card\">\n          <iframe\n            src=\"https://7dxperts.thoughtspot.cloud/?embedApp=true&orgId=1687366885&hideActions=true#/embed/viz/e6189c5d-537b-46b9-9af1-69d499b48907/1f526326-a9bb-42cf-993b-59da74ffbe60\"\n            width=\"100%\"\n            height=\"280\"\n            style=\"border: none; border-radius: 12px; background: #fff\"\n          >\n          </iframe>\n        </div>\n         \n        <div class=\"card\">\n          <iframe\n            src=\"https://7dxperts.thoughtspot.cloud/?embedApp=true&orgId=1687366885&hideActions=true#/embed/viz/e6189c5d-537b-46b9-9af1-69d499b48907/32ffcc39-570b-4e9d-90b3-4994fa964ef2\"\n            width=\"100%\"\n            height=\"280\"\n            style=\"border: none; border-radius: 12px; background: #fff\"\n          >\n          </iframe>\n        </div>\n         \n        <div class=\"card\">\n          <iframe\n            src=\"https://7dxperts.thoughtspot.cloud/?embedApp=true&orgId=1687366885&hideActions=true#/embed/viz/e6189c5d-537b-46b9-9af1-69d499b48907/baff4089-706e-43f6-aa0d-ae5a34ced8a6\"\n            width=\"100%\"\n            height=\"280\"\n            style=\"border: none; border-radius: 12px; background: #fff\"\n          >\n          </iframe>\n        </div>\n         \n        <div class=\"card\">\n          <iframe\n            src=\"https://7dxperts.thoughtspot.cloud/?embedApp=true&orgId=1687366885&hideActions=true#/embed/viz/e6189c5d-537b-46b9-9af1-69d499b48907/54157cce-bd11-4cc8-82ff-6dc6e19b767c\"\n            width=\"100%\"\n            height=\"280\"\n            style=\"border: none; border-radius: 12px; background: #fff\"\n          >\n          </iframe>\n        </div>\n        \n      </div>\n    </div>\n    <div class=\"footer\">\n      <a\n        class=\"btn\"\n        href=\"/custom/custom-1765964342909\"\n        style=\"background-color: #e40404; color: #FFFFFF\"\n        >View Liveboard</a\n      >\n      <a\n        class=\"btn inverse\"\n        href=\"/spotter\"\n        style=\"background-color: #e40404; color: #FFFFFF\"\n        >Spotter AI</a\n      >\n    </div>\n\n    <!-- Runtime Filter Implementation - CORRECTED -->\n    <script>\n      document.addEventListener(\"DOMContentLoaded\", () => {\n        if (!window.tsembed) {\n          console.warn(\"ThoughtSpot Embed SDK not available\");\n          return;\n        }\n\n        const { init, LiveboardEmbed, HostEvent, RuntimeFilterOp } =\n          window.tsembed;\n        const liveboardInstances = [];\n\n        // Extract IDs from hash-based URL format\n        function extractIdsFromUrl(url) {\n          try {\n            // Format: #/embed/viz/LIVEBOARD_ID/VIZ_ID\n            const hashPart = url.split(\"#\")[1];\n            if (!hashPart) return null;\n\n            const pathParts = hashPart.split(\"/\");\n            // pathParts = ['', 'embed', 'viz', 'LIVEBOARD_ID', 'VIZ_ID']\n\n            if (\n              pathParts.length >= 5 &&\n              pathParts[1] === \"embed\" &&\n              pathParts[2] === \"viz\"\n            ) {\n              return {\n                liveboardId: pathParts[3],\n                vizId: pathParts[4],\n              };\n            }\n            return null;\n          } catch (e) {\n            console.error(\"Error extracting IDs:\", e);\n            return null;\n          }\n        }\n\n        const iframes = document.querySelectorAll(\".cards-grid iframe\");\n        let initialized = false;\n\n        iframes.forEach((iframe, idx) => {\n          const src = iframe.getAttribute(\"src\") || \"\";\n          if (!src.includes(\"thoughtspot\")) return;\n\n          const host = new URL(src).origin;\n          const ids = extractIdsFromUrl(src);\n\n          if (!ids) {\n            console.warn(\"Could not extract IDs from URL:\", src);\n            return;\n          }\n\n          // Initialize SDK once\n          if (!initialized) {\n            init({\n              thoughtSpotHost: host,\n              authType: window.tsembed.AuthType.None, // or your auth type\n            });\n            initialized = true;\n          }\n\n          // Create container for embed\n          const containerId = `ts-embed-${idx}-${Math.random()\n            .toString(36)\n            .substr(2, 5)}`;\n          const wrapper = document.createElement(\"div\");\n          wrapper.id = containerId;\n          wrapper.style.width = \"100%\";\n          wrapper.style.height = \"280px\";\n          wrapper.style.borderRadius = \"16px\";\n          wrapper.style.overflow = \"hidden\";\n\n          iframe.parentNode.replaceChild(wrapper, iframe);\n\n          // Create LiveboardEmbed instance\n          const embed = new LiveboardEmbed(`#${containerId}`, {\n            liveboardId: ids.liveboardId,\n            vizId: ids.vizId,\n            hideActions: true,\n            fullHeight: false,\n            frameParams: {\n              width: \"100%\",\n              height: \"280px\",\n            },\n          });\n\n          // Render and store instance\n          embed\n            .render()\n            .then(() => {\n              liveboardInstances.push(embed);\n              console.log(`Embed ${idx} rendered successfully`);\n            })\n            .catch((err) => {\n              console.error(`Error rendering embed ${idx}:`, err);\n            });\n        });\n\n        // Track active filters\n        const activeFilters = {};\n\n        // Add click handlers to filter chips\n        document.querySelectorAll(\".filters .chip\").forEach((chip) => {\n          chip.addEventListener(\"click\", () => {\n            const col = chip.dataset.col || chip.innerText.split(\"(\")[0].trim();\n            const val = prompt(`Filter ${col} by:`);\n\n            if (val && val.trim()) {\n              activeFilters[col] = [val.trim()];\n              chip.classList.add(\"active\");\n            } else {\n              delete activeFilters[col];\n              chip.classList.remove(\"active\");\n            }\n\n            // Build runtime filters array\n            const runtimeFilters = Object.keys(activeFilters).map(\n              (columnName) => ({\n                columnName: columnName,\n                operator: RuntimeFilterOp.EQ,\n                values: activeFilters[columnName],\n              })\n            );\n\n            console.log(\"Applying filters:\", runtimeFilters);\n\n            // Apply filters to all embedded instances\n            liveboardInstances.forEach((lb, index) => {\n              try {\n                lb.trigger(HostEvent.UpdateRuntimeFilters, runtimeFilters);\n                console.log(`Filters applied to embed ${index}`);\n              } catch (err) {\n                console.error(`Error applying filters to embed ${index}:`, err);\n              }\n            });\n          });\n        });\n      });\n    </script>\n  </body>\n</html>\n"
    },
